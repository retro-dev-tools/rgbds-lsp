{
  "name": "rgbds-lsp",
  "description": "RGBDS Game Boy assembly language server — go-to-definition, find references, completion, hover, diagnostics, rename, document outline",
  "version": "0.1.3",
  "author": {
    "name": "rgbds-lsp contributors"
  },
  "repository": "https://github.com/minorum/rgbds-lsp",
  "license": "MIT",
  "keywords": ["gameboy", "rgbds", "assembly", "gbz80", "lsp"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm install --prefix \"${CLAUDE_PLUGIN_DATA}\" rgbds-language-server@0.1.3 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
