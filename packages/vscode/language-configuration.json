{
    "comments": {
        "lineComment": ";",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" }
    ],
    "surroundingPairs": [
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "indentationRules": {
        "increaseIndentPattern": "(?i)^\\s*(MACRO|IF|ELIF|ELSE|REPT|FOR|UNION|NEXTU)\\b",
        "decreaseIndentPattern": "(?i)^\\s*(ENDM|ENDC|ELSE|ELIF|ENDR|ENDU|NEXTU|ENDSECTION)\\b"
    }
}
