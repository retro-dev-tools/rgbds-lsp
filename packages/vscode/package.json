{
  "name": "rgbds-lsp",
  "displayName": "RGBDS Assembly",
  "description": "Language support for RGBDS Game Boy assembly — go-to-definition, find references, completion, diagnostics, rename, syntax highlighting",
  "version": "0.2.0",
  "license": "MIT",
  "publisher": "rgbds-lsp",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0f380f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/retro-dev-tools/rgbds-lsp"
  },
  "bugs": {
    "url": "https://github.com/retro-dev-tools/rgbds-lsp/issues"
  },
  "homepage": "https://github.com/retro-dev-tools/rgbds-lsp#readme",
  "keywords": [
    "rgbds",
    "gameboy",
    "game boy",
    "assembly",
    "gbz80",
    "sm83",
    "lsp",
    "language server"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "rgbds",
        "aliases": [
          "RGBDS Assembly",
          "rgbds",
          "gbz80",
          "sm83"
        ],
        "extensions": [
          ".asm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rgbds",
        "scopeName": "source.rgbds",
        "path": "./syntaxes/rgbds.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "RGBDS Assembly",
      "properties": {
        "rgbds.maxDiagnostics": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "scope": "resource",
          "markdownDescription": "Maximum number of diagnostics per file"
        },
        "rgbds.serverPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "Path to rgbds-language-server module. Leave empty to auto-detect from global install."
        },
        "rgbds.buildCommand": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "tags": ["experimental"],
          "markdownDescription": "Shell command to build the ROM (e.g., `make`). Runs automatically when `.asm`/`.inc` files are saved, producing the ROM and `.sym` file needed for inlay hints. **Experimental**"
        },
        "rgbds.romPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "tags": ["experimental"],
          "markdownDescription": "Path to the built ROM file (`.gb`/`.gbc`). Leave empty for auto-detect. **Experimental**"
        },
        "rgbds.symPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "tags": ["experimental"],
          "markdownDescription": "Path to the symbol file (`.sym`). Leave empty for auto-detect. **Experimental**"
        },
        "rgbds.validateCommentBytes": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Warn when hex byte annotations in comments (e.g., `; $3E $00`) don't match the computed assembled bytes"
        },
        "rgbds.assembledBytes.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "tags": ["experimental"],
          "markdownDescription": "Show assembled hex bytes as decorations next to source lines. **Experimental**"
        },
        "rgbds.assembledBytes.maxBytesPerLine": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "scope": "resource",
          "tags": ["experimental"],
          "markdownDescription": "Maximum number of hex bytes to display per line. **Experimental**"
        },
        "rgbds.assembledBytes.alignColumn": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "scope": "resource",
          "tags": ["experimental"],
          "markdownDescription": "Column to align hex byte decorations to. **Experimental**"
        },
        "rgbds.inlayHints.constantValues": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "markdownDescription": "Show resolved values of constants inline (e.g., `= $FF40` after `LCDC_CTRL`)"
        },
        "rgbds.inlayHints.macroParameters": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Show parameter numbers at macro call sites (e.g., `\\1:` before the first argument)"
        }
      }
    },
    "commands": [
      {
        "command": "rgbds.configureBuild",
        "title": "Configure Build",
        "category": "RGBDS"
      },
      {
        "command": "rgbds.clearCache",
        "title": "Clear Index Cache",
        "category": "RGBDS"
      }
    ],
    "problemMatchers": [
      {
        "name": "rgbdserror",
        "owner": "rgbds",
        "fileLocation": ["autoDetect", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?)\\((\\d+)\\):\\s+(warning|ERROR):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      },
      {
        "name": "rgbdslinkerror",
        "owner": "rgbds",
        "fileLocation": ["autoDetect", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^(?:(.+?)\\((\\d+)\\):\\s+)?(warning|error|ERROR):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "severity": 3,
            "message": 4
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "npx esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "clean": "rm -rf out",
    "vscode:prepublish": "npm run build -- --minify",
    "package": "npx @vscode/vsce package -o rgbds-lsp.vsix --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.4"
  }
}
